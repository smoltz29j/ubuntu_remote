<Window x:Class="UbuntuRemote.ProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="接続プロファイル"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,12,8"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Padding" Value="4,3"/>
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Padding" Value="4,3"/>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
        </Grid.Resources>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="表示名:"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="ホスト:"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="HostBox"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="ポート:"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PortBox" Text="3389"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="ユーザー名:"/>
        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="UsernameBox"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="パスワード:"/>
        <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox"/>

        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PasswordHint"
                   Text="(空欄のままにすると保存済みのパスワードを維持します)"
                   FontSize="11" Foreground="Gray" Margin="0,-4,0,8"
                   Visibility="Collapsed"/>

        <CheckBox Grid.Row="6" Grid.Column="1" x:Name="ClipboardCheck"
                  Content="クリップボードを共有する" IsChecked="True"/>
        <CheckBox Grid.Row="7" Grid.Column="1" x:Name="DrivesCheck"
                  Content="ローカルドライブを共有する"/>

        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="90" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="キャンセル" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
